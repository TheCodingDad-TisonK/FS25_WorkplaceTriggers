    <version>1.0.7.0</version>
    <modName>FS25_WorkplaceTriggers</modName>

    <title>
        <en>Workplace Triggers - Work Anywhere</en>
        <de>Arbeitsstellen-Trigger - Überall arbeiten</de>
        <fr>Déclencheurs de lieu de travail - Travaillez partout</fr>
        <it>Trigger di lavoro - Lavora ovunque</it>
        <nl>Werkplek triggers - Werk overal</nl>
        <pl>Wyzwalacze miejsca pracy - Pracuj wszedzie</pl>
    </title>

    <description>
        <en><![CDATA[Turn any location on any map into a legitimate workplace.

Place a trigger anywhere, name it, set a wage, and earn income while you are on the clock. Perfect for roleplayers who want their farmers to have side jobs, or anyone who wants to supplement farm income with off-farm work.

FEATURES:
- Placeable trigger zones - invisible zones you drop anywhere on any map
- Custom workplace names - call it Post Office, Feed Mill, or anything you want
- Flexible pay schedules - Hourly, Flat Rate per shift, or Daily rate
- Shift tracking HUD - see your active workplace, earnings, and shift time
- Workplace manager - full GUI to view, edit, and delete all triggers
- Persistent saves - all triggers, names, wages, and pay schedules survive reloads
- Multiplayer-aware - each player tracks their own shifts; earnings go to the shared farm account
- Optional FS25_NPCFavor integration - working shifts builds relationship with employer NPCs
- Optional FS25_WorkerCosts integration - shift income is tracked alongside AI worker wages

HOW TO USE:
1. Press [F4] to open the Workplace Manager and click Add to create a new trigger
2. Name the workplace, set a wage, and choose a pay schedule - then confirm
3. Place the trigger at any location on the map
4. Walk into the trigger zone - press [E] to start your shift
5. Press [E] again to end your shift and collect your wages

Type wtHelp in the developer console for debug commands.
        ]]></en>
        <de><![CDATA[Verwandle jeden Ort auf jeder Karte in einen legitimen Arbeitsplatz.

Platziere einen Trigger, benenne ihn, lege einen Lohn fest und verdiene Einnahmen, waehrend du auf der Uhr bist.

FUNKTIONEN:
- Platzierbare Trigger-Zonen
- Benutzerdefinierte Arbeitsplatznamen
- Stuendliches Lohnsystem
- Schicht-HUD
- Persistente Speicherung
        ]]></de>
        <fr><![CDATA[Transformez n'importe quel endroit en lieu de travail.

Placez un declencheur, nommez-le, definissez un salaire et gagnez des revenus pendant que vous etes au travail.
        ]]></fr>
        <it><![CDATA[Trasforma qualsiasi luogo in un posto di lavoro legittimo.

Posiziona un trigger, assegnagli un nome, imposta uno stipendio e guadagna durante il turno.
        ]]></it>
        <nl><![CDATA[Maak van elke locatie een legitieme werkplek.

Plaats een trigger, geef het een naam, stel een loon in en verdien inkomen terwijl je aan het werk bent.
        ]]></nl>
        <pl><![CDATA[Zamien dowolna lokalizacje w legalne miejsce pracy.

Umiec wyzwalacz, nadaj mu nazwe, ustaw stawke i zarabiaj podczas dyspozycji.
        ]]></pl>
    </description>

    <iconFilename>icon_wt.dds</iconFilename>

    <l10n filenamePrefix="translations/lang" defaultLanguage="en"/>

    <multiplayer supported="true"/>

    <extraSourceFiles>
        <sourceFile filename="main.lua"/>
    </extraSourceFiles>

    <actions>
        <action name="WT_INTERACT"/>
        <action name="WT_MENU"/>
        <action name="WT_HUD_EDIT"/>
    </actions>
    <inputBinding>
        <actionBinding action="WT_INTERACT">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_e"/>
        </actionBinding>
        <actionBinding action="WT_MENU">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_F4"/>
        </actionBinding>
        <actionBinding action="WT_HUD_EDIT">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_F7"/>
        </actionBinding>
    </inputBinding>

    <placeableSpecializations>
        <specialization name="workTrigger" className="WorkTriggerPlaceable" filename="placeables/workTrigger/workTrigger.lua"/>
    </placeableSpecializations>

    <placeableTypes>
        <type name="workTrigger" parent="simplePlaceable" filename="$dataS/scripts/placeables/Placeable.lua">
            <specialization name="workTrigger"/>
        </type>
    </placeableTypes>

    <storePacks>
        <storePack name="WT_WORKPLACE_TRIGGERS"
                   title="$l10n_storePack_wt_title"
                   image="icon_wt.dds"/>
    </storePacks>

    <storeItems>
        <storeItem xmlFilename="placeables/workTrigger/workTrigger.xml"/>
    </storeItems>

