<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    FS25_WorkplaceTriggers - Edit / Create Trigger Dialog
    Dialog width: 560px. Content anchor = top-center, X=0 is dialog center.
    Safe horizontal range: approx -240px to +240px.

    Layout (Y from top, increases downward):
      -12   Title text
      -32   Divider line
      -44   "Workplace Name" section label
      -62   Name TextInput (460px, centered)
      -90   "Hourly Wage" section label
      -110  Wage row: -60 [-]  0 [value]  +60 [+]
      -130  "Step:" label
      -144  Step buttons: -50 / 0 / +50
      -164  "Trigger Radius" section label
      -182  Radius row: -60 [-]  0 [value]  +60 [+]
      -202  Divider
      -216  Position text (centered)
      -238  Snap button (centered)
      -258  Status text
-->
<GUI onOpen="onOpen" onClose="wtOnClose" onCreate="onCreate">
    <GuiElement profile="newLayer" />
    <Bitmap profile="dialogFullscreenBg" id="dialogBg" />

    <GuiElement profile="dialogBg" id="dialogElement" size="560px 540px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle" />
        <ThreePartBitmap profile="fs25_dialogBgTop" />
        <ThreePartBitmap profile="fs25_dialogBgBottom" />

        <GuiElement profile="fs25_dialogContentContainer">

            <!-- Title -->
            <Text   profile="wtEditTitle"   id="titleText" position="0px -12px" text=""/>
            <Bitmap profile="wtEditDivider"                position="0px -32px"/>

            <!-- NAME -->
            <Text      profile="wtSectionLabel"                position="0px -44px"  text="Workplace Name"/>
            <TextInput profile="wtNameInput"    id="nameInput" position="0px -62px"
                       onEnterPress="onClickSave"/>

            <!-- WAGE -->
            <Text profile="wtSectionLabel" position="0px -90px" text="Hourly Wage"/>

            <Bitmap profile="wtAdjBtnBg"   id="wageDecBg"  position="-60px -110px"/>
            <Text   profile="wtAdjBtnText" id="wageDecTxt" position="-60px -111px" text="-"/>
            <Button profile="wtAdjBtnHit"  id="wageDec"    position="-60px -110px" onClick="onClickWageDec"/>

            <Text profile="wtValueText" id="wageText" position="0px -110px" text="$500/hr"/>

            <Bitmap profile="wtAdjBtnBg"   id="wageIncBg"  position="60px -110px"/>
            <Text   profile="wtAdjBtnText" id="wageIncTxt" position="60px -111px" text="+"/>
            <Button profile="wtAdjBtnHit"  id="wageInc"    position="60px -110px" onClick="onClickWageInc"/>

            <!-- Step selector -->
            <Text profile="wtStepCaption" position="0px -130px" text="Step:"/>

            <Bitmap profile="wtStepBg"   id="step1bg"   position="-50px -144px"/>
            <Text   profile="wtStepText" id="step1txt"  position="-50px -145px" text="x1"/>
            <Button profile="wtStepHit"  id="step1"     position="-50px -144px" onClick="onClickStep1"/>

            <Bitmap profile="wtStepBg"   id="step10bg"  position="0px -144px"/>
            <Text   profile="wtStepText" id="step10txt" position="0px -145px"   text="x10"/>
            <Button profile="wtStepHit"  id="step10"    position="0px -144px"   onClick="onClickStep10"/>

            <Bitmap profile="wtStepBg"   id="step100bg"  position="50px -144px"/>
            <Text   profile="wtStepText" id="step100txt" position="50px -145px"  text="x100"/>
            <Button profile="wtStepHit"  id="step100"    position="50px -144px"  onClick="onClickStep100"/>

            <!-- RADIUS -->
            <Text profile="wtSectionLabel" position="0px -164px" text="Trigger Radius"/>

            <Bitmap profile="wtAdjBtnBg"   id="radDecBg"  position="-60px -182px"/>
            <Text   profile="wtAdjBtnText" id="radDecTxt" position="-60px -183px" text="-"/>
            <Button profile="wtAdjBtnHit"  id="radDec"    position="-60px -182px" onClick="onClickRadDec"/>

            <Text profile="wtValueText" id="radText" position="0px -182px" text="4 m"/>

            <Bitmap profile="wtAdjBtnBg"   id="radIncBg"  position="60px -182px"/>
            <Text   profile="wtAdjBtnText" id="radIncTxt" position="60px -183px" text="+"/>
            <Button profile="wtAdjBtnHit"  id="radInc"    position="60px -182px" onClick="onClickRadInc"/>

            <!-- PAY SCHEDULE -->
            <Text profile="wtSectionLabel" position="0px -205px" text="Pay Schedule"/>

            <Bitmap profile="wtSchedBg"   id="schedHourlyBg"  position="-90px -220px"/>
            <Text   profile="wtSchedText" id="schedHourlyTxt" position="-90px -221px" text="Hourly"/>
            <Button profile="wtSchedHit"  id="schedHourly"    position="-90px -220px" onClick="onClickSchedHourly"/>

            <Bitmap profile="wtSchedBg"   id="schedFlatBg"  position="0px -220px"/>
            <Text   profile="wtSchedText" id="schedFlatTxt" position="0px -221px"   text="Flat Rate"/>
            <Button profile="wtSchedHit"  id="schedFlat"    position="0px -220px"   onClick="onClickSchedFlat"/>

            <Bitmap profile="wtSchedBg"   id="schedDailyBg"  position="90px -220px"/>
            <Text   profile="wtSchedText" id="schedDailyTxt" position="90px -221px"  text="Daily"/>
            <Button profile="wtSchedHit"  id="schedDaily"    position="90px -220px"  onClick="onClickSchedDaily"/>

            <Text profile="wtSchedHint" id="schedHintText" position="0px -238px" text=""/>

            <!-- TIME MULTIPLIER -->
            <Text profile="wtSectionLabel" position="0px -254px" text="Time Multiplier"/>

            <Bitmap profile="wtStepBg"   id="timeMult1Bg"   position="-110px -268px"/>
            <Text   profile="wtStepText" id="timeMult1Txt"  position="-110px -269px" text="x1"/>
            <Button profile="wtStepHit"  id="timeMult1"     position="-110px -268px" onClick="onClickTimeMult1"/>

            <Bitmap profile="wtStepBg"   id="timeMult3Bg"   position="-55px -268px"/>
            <Text   profile="wtStepText" id="timeMult3Txt"  position="-55px -269px"  text="x3"/>
            <Button profile="wtStepHit"  id="timeMult3"     position="-55px -268px"  onClick="onClickTimeMult3"/>

            <Bitmap profile="wtStepBg"   id="timeMult0Bg"   position="0px -268px"/>
            <Text   profile="wtStepText" id="timeMult0Txt"  position="0px -269px"    text="Auto"/>
            <Button profile="wtStepHit"  id="timeMult0"     position="0px -268px"    onClick="onClickTimeMultAuto"/>

            <Bitmap profile="wtStepBg"   id="timeMult5Bg"   position="55px -268px"/>
            <Text   profile="wtStepText" id="timeMult5Txt"  position="55px -269px"   text="x5"/>
            <Button profile="wtStepHit"  id="timeMult5"     position="55px -268px"   onClick="onClickTimeMult5"/>

            <Bitmap profile="wtStepBg"   id="timeMult10Bg"  position="110px -268px"/>
            <Text   profile="wtStepText" id="timeMult10Txt" position="110px -269px"  text="x10"/>
            <Button profile="wtStepHit"  id="timeMult10"    position="110px -268px"  onClick="onClickTimeMult10"/>

            <Text profile="wtSchedHint" id="timeModeHint" position="0px -284px" text=""/>

            <!-- POSITION + SNAP -->
            <Bitmap profile="wtEditDivider" position="0px -298px"/>

            <Text profile="wtPosText" id="posText" position="0px -312px" text="Position: X=0  Z=0"/>

            <Bitmap profile="wtSnapBg"   id="snapBg"  position="0px -330px"/>
            <Text   profile="wtSnapText" id="snapTxt" position="0px -331px" text="Snap to Player Position"/>
            <Button profile="wtSnapHit"  id="snapBtn" position="0px -330px" onClick="onClickSnap"/>

            <!-- Status -->
            <Text profile="wtStatusText" id="statusText" position="0px -352px" text=""/>

        </GuiElement>

        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonOK"   id="btnSave"   text="Save"   onClick="onClickSave"/>
            <Button profile="buttonBack" id="btnCancel" text="Cancel" onClick="onClickCancel"/>
        </BoxLayout>

    </GuiElement>

    <GUIProfiles>
        <Profile name="fs25_guiElement" extends="baseReference"/>

        <Profile name="wtEditTitle" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="500px 24px"/>
            <textSize value="18px"/>
            <textBold value="true"/>
            <textColor value="1 1 1 1"/>
            <textAlignment value="center"/>
        </Profile>

        <Profile name="wtEditDivider" extends="baseReference" with="anchorTopCenter">
            <size value="500px 1px"/>
            <imageColor value="0.28 0.38 0.55 0.7"/>
        </Profile>

        <!-- Section caption: centred, subdued blue-grey -->
        <Profile name="wtSectionLabel" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="500px 14px"/>
            <textSize value="11px"/>
            <textBold value="false"/>
            <textColor value="0.55 0.65 0.82 1"/>
            <textAlignment value="center"/>
        </Profile>

        <Profile name="wtNameInput" extends="fs25_textInput" with="anchorTopCenter">
            <size value="460px 24px"/>
        </Profile>

        <!-- +/- button bg: rich blue -->
        <Profile name="wtAdjBtnBg" extends="baseReference" with="anchorTopCenter">
            <size value="40px 22px"/>
            <imageColor value="0.14 0.26 0.50 1"/>
        </Profile>
        <!-- +/- label: pure white for maximum legibility -->
        <Profile name="wtAdjBtnText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="40px 20px"/>
            <textSize value="16px"/>
            <textBold value="true"/>
            <textColor value="1 1 1 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="wtAdjBtnHit" extends="emptyPanel" with="anchorTopCenter">
            <size value="40px 22px"/>
            <isFocusable value="true"/>
        </Profile>

        <!-- Value display: bright green -->
        <Profile name="wtValueText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="100px 22px"/>
            <textSize value="15px"/>
            <textBold value="true"/>
            <textColor value="0.35 0.90 0.45 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- "Step:" caption: very muted -->
        <Profile name="wtStepCaption" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="400px 12px"/>
            <textSize value="10px"/>
            <textColor value="0.40 0.46 0.58 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Step button bg: dark slate (inactive) -->
        <Profile name="wtStepBg" extends="baseReference" with="anchorTopCenter">
            <size value="44px 16px"/>
            <imageColor value="0.10 0.14 0.28 1"/>
        </Profile>
        <!-- Step label: pale blue -->
        <Profile name="wtStepText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="44px 14px"/>
            <textSize value="10px"/>
            <textBold value="true"/>
            <textColor value="0.70 0.80 0.95 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="wtStepHit" extends="emptyPanel" with="anchorTopCenter">
            <size value="44px 16px"/>
            <isFocusable value="true"/>
        </Profile>

        <!-- Position display: muted grey -->
        <Profile name="wtPosText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="500px 14px"/>
            <textSize value="11px"/>
            <textColor value="0.52 0.60 0.72 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Snap button: amber/gold, centered, wider -->
        <Profile name="wtSnapBg" extends="baseReference" with="anchorTopCenter">
            <size value="210px 18px"/>
            <imageColor value="0.30 0.20 0.03 1"/>
        </Profile>
        <Profile name="wtSnapText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="210px 16px"/>
            <textSize value="10px"/>
            <textBold value="true"/>
            <textColor value="1.0 0.84 0.28 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="wtSnapHit" extends="emptyPanel" with="anchorTopCenter">
            <size value="210px 18px"/>
            <isFocusable value="true"/>
        </Profile>

        <!-- Status / feedback: bright green -->
        <Profile name="wtStatusText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="500px 14px"/>
            <textSize value="10px"/>
            <textColor value="0.38 0.92 0.50 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Pay schedule toggle buttons -->
        <Profile name="wtSchedBg" extends="baseReference" with="anchorTopCenter">
            <size value="80px 16px"/>
            <imageColor value="0.10 0.14 0.28 1"/>
        </Profile>
        <Profile name="wtSchedText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="80px 14px"/>
            <textSize value="10px"/>
            <textBold value="true"/>
            <textColor value="0.70 0.80 0.95 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="wtSchedHit" extends="emptyPanel" with="anchorTopCenter">
            <size value="80px 16px"/>
            <isFocusable value="true"/>
        </Profile>
        <Profile name="wtSchedHint" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="480px 13px"/>
            <textSize value="10px"/>
            <textColor value="0.48 0.56 0.70 1"/>
            <textAlignment value="center"/>
        </Profile>

    </GUIProfiles>
</GUI>
