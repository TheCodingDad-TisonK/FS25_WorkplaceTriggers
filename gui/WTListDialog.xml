<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    WTListDialog — FS25_WorkplaceTriggers
    Structure: verbatim copy of CTManagementDialog (FS25_CustomTriggerCreator).
    Only changes: profile prefix mg->wt, IDs mg_rN->rN, callbacks, column labels,
    8 rows instead of 10, bottom section shifted up 38px accordingly.

    Column X (CTC proven positions, single-space in position attributes):
      Name  (200px): center=-270px  (CTC Name)
      Wage   (90px): center=-95px   (CTC Category)
      Sched (120px): center=60px    (CTC Type)
      Edit   (44px): center=285px   (CTC RUN)
      Del    (44px): center=333px   (CTC TOG)
-->
<GUI onOpen="onOpen" onClose="wtOnClose" onCreate="onCreate">
    <GuiElement profile="newLayer" />
    <Bitmap profile="dialogFullscreenBg" id="dialogBg" />

    <GuiElement profile="dialogBg" id="dialogElement" size="880px 580px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle" />
        <ThreePartBitmap profile="fs25_dialogBgTop" />
        <ThreePartBitmap profile="fs25_dialogBgBottom" />

        <GuiElement profile="fs25_dialogContentContainer">

            <!-- ===== TITLE ===== -->
            <Text profile="wtTitle" id="titleText" position="0px -12px" text="Workplace Triggers"/>
            <Text profile="wtSubtitle" id="subtitleText" position="0px -36px" text=""/>

            <!-- ===== HEADER DIVIDER ===== -->
            <Bitmap profile="wtDivider" position="0px -54px"/>

            <!-- ===== COLUMN HEADERS ===== -->
            <Text profile="wtHdrName" position="-270px -58px" text="Workplace Name"/>
            <Text profile="wtHdrWage" position="-95px -58px" text="Wage"/>
            <Text profile="wtHdrPos"  position="60px -58px" text="Sched / Radius"/>

            <!-- ===== HEADER UNDERLINE ===== -->
            <Bitmap profile="wtDivider" position="0px -73px"/>

            <!-- ===== ROW 1 ===== -->
            <Bitmap profile="wtRowOdd"   id="r1bg"      position="0px -76px"/>
            <Text   profile="wtCellName" id="r1name"    position="-270px -77px" text=""/>
            <Text   profile="wtCellWage" id="r1wage"    position="-95px -77px" text=""/>
            <Text   profile="wtCellPos"  id="r1pos"     position="60px -77px" text=""/>
            <Bitmap profile="wtBtnBg"    id="r1editbg"  position="285px -77px"/>
            <Text   profile="wtBtnText"  id="r1edittxt" position="285px -78px" text="Edit"/>
            <Button profile="wtBtnHit"   id="r1edit"    position="285px -77px" onClick="onClickEdit1" toolTip="Edit trigger"/>
            <Bitmap profile="wtDelBg"    id="r1delbg"   position="333px -77px"/>
            <Text   profile="wtDelText"  id="r1deltxt"  position="333px -78px" text="Del"/>
            <Button profile="wtDelHit"   id="r1del"     position="333px -77px" onClick="onClickDel1" toolTip="Delete trigger"/>

            <!-- ===== ROW 2 ===== -->
            <Bitmap profile="wtRowEven"  id="r2bg"      position="0px -95px"/>
            <Text   profile="wtCellName" id="r2name"    position="-270px -96px" text=""/>
            <Text   profile="wtCellWage" id="r2wage"    position="-95px -96px" text=""/>
            <Text   profile="wtCellPos"  id="r2pos"     position="60px -96px" text=""/>
            <Bitmap profile="wtBtnBg"    id="r2editbg"  position="285px -96px"/>
            <Text   profile="wtBtnText"  id="r2edittxt" position="285px -97px" text="Edit"/>
            <Button profile="wtBtnHit"   id="r2edit"    position="285px -96px" onClick="onClickEdit2" toolTip="Edit trigger"/>
            <Bitmap profile="wtDelBg"    id="r2delbg"   position="333px -96px"/>
            <Text   profile="wtDelText"  id="r2deltxt"  position="333px -97px" text="Del"/>
            <Button profile="wtDelHit"   id="r2del"     position="333px -96px" onClick="onClickDel2" toolTip="Delete trigger"/>

            <!-- ===== ROW 3 ===== -->
            <Bitmap profile="wtRowOdd"   id="r3bg"      position="0px -114px"/>
            <Text   profile="wtCellName" id="r3name"    position="-270px -115px" text=""/>
            <Text   profile="wtCellWage" id="r3wage"    position="-95px -115px" text=""/>
            <Text   profile="wtCellPos"  id="r3pos"     position="60px -115px" text=""/>
            <Bitmap profile="wtBtnBg"    id="r3editbg"  position="285px -115px"/>
            <Text   profile="wtBtnText"  id="r3edittxt" position="285px -116px" text="Edit"/>
            <Button profile="wtBtnHit"   id="r3edit"    position="285px -115px" onClick="onClickEdit3" toolTip="Edit trigger"/>
            <Bitmap profile="wtDelBg"    id="r3delbg"   position="333px -115px"/>
            <Text   profile="wtDelText"  id="r3deltxt"  position="333px -116px" text="Del"/>
            <Button profile="wtDelHit"   id="r3del"     position="333px -115px" onClick="onClickDel3" toolTip="Delete trigger"/>

            <!-- ===== ROW 4 ===== -->
            <Bitmap profile="wtRowEven"  id="r4bg"      position="0px -133px"/>
            <Text   profile="wtCellName" id="r4name"    position="-270px -134px" text=""/>
            <Text   profile="wtCellWage" id="r4wage"    position="-95px -134px" text=""/>
            <Text   profile="wtCellPos"  id="r4pos"     position="60px -134px" text=""/>
            <Bitmap profile="wtBtnBg"    id="r4editbg"  position="285px -134px"/>
            <Text   profile="wtBtnText"  id="r4edittxt" position="285px -135px" text="Edit"/>
            <Button profile="wtBtnHit"   id="r4edit"    position="285px -134px" onClick="onClickEdit4" toolTip="Edit trigger"/>
            <Bitmap profile="wtDelBg"    id="r4delbg"   position="333px -134px"/>
            <Text   profile="wtDelText"  id="r4deltxt"  position="333px -135px" text="Del"/>
            <Button profile="wtDelHit"   id="r4del"     position="333px -134px" onClick="onClickDel4" toolTip="Delete trigger"/>

            <!-- ===== ROW 5 ===== -->
            <Bitmap profile="wtRowOdd"   id="r5bg"      position="0px -152px"/>
            <Text   profile="wtCellName" id="r5name"    position="-270px -153px" text=""/>
            <Text   profile="wtCellWage" id="r5wage"    position="-95px -153px" text=""/>
            <Text   profile="wtCellPos"  id="r5pos"     position="60px -153px" text=""/>
            <Bitmap profile="wtBtnBg"    id="r5editbg"  position="285px -153px"/>
            <Text   profile="wtBtnText"  id="r5edittxt" position="285px -154px" text="Edit"/>
            <Button profile="wtBtnHit"   id="r5edit"    position="285px -153px" onClick="onClickEdit5" toolTip="Edit trigger"/>
            <Bitmap profile="wtDelBg"    id="r5delbg"   position="333px -153px"/>
            <Text   profile="wtDelText"  id="r5deltxt"  position="333px -154px" text="Del"/>
            <Button profile="wtDelHit"   id="r5del"     position="333px -153px" onClick="onClickDel5" toolTip="Delete trigger"/>

            <!-- ===== ROW 6 ===== -->
            <Bitmap profile="wtRowEven"  id="r6bg"      position="0px -171px"/>
            <Text   profile="wtCellName" id="r6name"    position="-270px -172px" text=""/>
            <Text   profile="wtCellWage" id="r6wage"    position="-95px -172px" text=""/>
            <Text   profile="wtCellPos"  id="r6pos"     position="60px -172px" text=""/>
            <Bitmap profile="wtBtnBg"    id="r6editbg"  position="285px -172px"/>
            <Text   profile="wtBtnText"  id="r6edittxt" position="285px -173px" text="Edit"/>
            <Button profile="wtBtnHit"   id="r6edit"    position="285px -172px" onClick="onClickEdit6" toolTip="Edit trigger"/>
            <Bitmap profile="wtDelBg"    id="r6delbg"   position="333px -172px"/>
            <Text   profile="wtDelText"  id="r6deltxt"  position="333px -173px" text="Del"/>
            <Button profile="wtDelHit"   id="r6del"     position="333px -172px" onClick="onClickDel6" toolTip="Delete trigger"/>

            <!-- ===== ROW 7 ===== -->
            <Bitmap profile="wtRowOdd"   id="r7bg"      position="0px -190px"/>
            <Text   profile="wtCellName" id="r7name"    position="-270px -191px" text=""/>
            <Text   profile="wtCellWage" id="r7wage"    position="-95px -191px" text=""/>
            <Text   profile="wtCellPos"  id="r7pos"     position="60px -191px" text=""/>
            <Bitmap profile="wtBtnBg"    id="r7editbg"  position="285px -191px"/>
            <Text   profile="wtBtnText"  id="r7edittxt" position="285px -192px" text="Edit"/>
            <Button profile="wtBtnHit"   id="r7edit"    position="285px -191px" onClick="onClickEdit7" toolTip="Edit trigger"/>
            <Bitmap profile="wtDelBg"    id="r7delbg"   position="333px -191px"/>
            <Text   profile="wtDelText"  id="r7deltxt"  position="333px -192px" text="Del"/>
            <Button profile="wtDelHit"   id="r7del"     position="333px -191px" onClick="onClickDel7" toolTip="Delete trigger"/>

            <!-- ===== ROW 8 ===== -->
            <Bitmap profile="wtRowEven"  id="r8bg"      position="0px -209px"/>
            <Text   profile="wtCellName" id="r8name"    position="-270px -210px" text=""/>
            <Text   profile="wtCellWage" id="r8wage"    position="-95px -210px" text=""/>
            <Text   profile="wtCellPos"  id="r8pos"     position="60px -210px" text=""/>
            <Bitmap profile="wtBtnBg"    id="r8editbg"  position="285px -210px"/>
            <Text   profile="wtBtnText"  id="r8edittxt" position="285px -211px" text="Edit"/>
            <Button profile="wtBtnHit"   id="r8edit"    position="285px -210px" onClick="onClickEdit8" toolTip="Edit trigger"/>
            <Bitmap profile="wtDelBg"    id="r8delbg"   position="333px -210px"/>
            <Text   profile="wtDelText"  id="r8deltxt"  position="333px -211px" text="Del"/>
            <Button profile="wtDelHit"   id="r8del"     position="333px -210px" onClick="onClickDel8" toolTip="Delete trigger"/>

            <!-- ===== BOTTOM DIVIDER ===== -->
            <Bitmap profile="wtDivider" position="0px -228px"/>

            <!-- ===== STATUS TEXT ===== -->
            <Text profile="wtFooter" id="statusText" position="-150px -233px" text=""/>

            <!-- ===== PAGINATION ===== -->
            <Bitmap profile="wtPageBg"   id="prevBg"   position="-385px -254px"/>
            <Text   profile="wtPageText" id="prevText" position="-385px -256px" text="&lt; Prev"/>
            <Button profile="wtPageHit"  id="prevBtn"  position="-385px -254px" onClick="onClickPrev"/>

            <Text   profile="wtPageInfo" id="pageInfo" position="-310px -256px" text="1 / 1"/>

            <Bitmap profile="wtPageBg"   id="nextBg"   position="-215px -254px"/>
            <Text   profile="wtPageText" id="nextText" position="-215px -256px" text="Next &gt;"/>
            <Button profile="wtPageHit"  id="nextBtn"  position="-215px -254px" onClick="onClickNext"/>

            <!-- ===== NEW TRIGGER BUTTON (admin-only, 3-layer for Lua show/hide) ===== -->
            <Bitmap profile="wtNewBg"   id="newBg"  position="300px -254px"/>
            <Text   profile="wtNewText" id="newTxt" position="300px -256px" text="+ New Trigger"/>
            <Button profile="wtNewHit"  id="newBtn" position="300px -254px" onClick="onClickNew"/>

        </GuiElement>

        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonBack" id="btnClose" text="Close" onClick="onClickClose"/>
        </BoxLayout>

    </GuiElement>

    <GUIProfiles>
        <Profile name="fs25_guiElement" extends="baseReference"/>

        <!-- Title / subtitle -->
        <Profile name="wtTitle" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="820px 22px"/>
            <textSize value="20px"/>
            <textBold value="true"/>
            <textColor value="1 1 1 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="wtSubtitle" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="820px 16px"/>
            <textSize value="12px"/>
            <textColor value="0.55 0.75 0.9 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Divider -->
        <Profile name="wtDivider" extends="baseReference" with="anchorTopCenter">
            <size value="820px 1px"/>
            <imageColor value="0.3 0.35 0.45 0.8"/>
        </Profile>

        <!-- Column headers: base carries anchorTopCenter, leaves do not (CTC pattern) -->
        <Profile name="wtHdrBase" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="11px"/>
            <textBold value="true"/>
            <textColor value="0.55 0.7 0.9 1"/>
        </Profile>
        <Profile name="wtHdrName" extends="wtHdrBase"> <size value="200px 14px"/> <textAlignment value="left"/> </Profile>
        <Profile name="wtHdrWage" extends="wtHdrBase"> <size value="90px 14px"/> <textAlignment value="left"/> </Profile>
        <Profile name="wtHdrPos"  extends="wtHdrBase"> <size value="120px 14px"/> <textAlignment value="left"/> </Profile>

        <!-- Row backgrounds -->
        <Profile name="wtRowOdd"  extends="baseReference" with="anchorTopCenter">
            <size value="820px 18px"/>
            <imageColor value="0.08 0.09 0.12 0.6"/>
        </Profile>
        <Profile name="wtRowEven" extends="baseReference" with="anchorTopCenter">
            <size value="820px 18px"/>
            <imageColor value="0.06 0.06 0.09 0.4"/>
        </Profile>

        <!-- Table cells: base carries anchorTopCenter, leaves do not (CTC pattern) -->
        <Profile name="wtCellBase" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="12px"/>
            <textColor value="0.82 0.82 0.82 1"/>
        </Profile>
        <Profile name="wtCellName" extends="wtCellBase"> <size value="200px 16px"/> <textAlignment value="left"/> <textBold value="true"/> <textColor value="1 1 1 1"/> </Profile>
        <Profile name="wtCellWage" extends="wtCellBase"> <size value="90px 16px"/> <textAlignment value="left"/> <textColor value="0.35 0.88 0.42 1"/> </Profile>
        <Profile name="wtCellPos"  extends="wtCellBase"> <size value="120px 16px"/> <textAlignment value="left"/> <textColor value="0.62 0.72 0.85 1"/> </Profile>

        <!-- Edit button (blue) — verbatim CTC mgRunBg/Text/Hit -->
        <Profile name="wtBtnBg"   extends="baseReference"   with="anchorTopCenter"> <size value="44px 16px"/> <imageColor value="0.10 0.16 0.32 0.95"/> </Profile>
        <Profile name="wtBtnText" extends="fs25_textDefault" with="anchorTopCenter"> <size value="44px 14px"/> <textSize value="10px"/> <textBold value="true"/> <textColor value="0.6 0.8 1 1"/> <textAlignment value="center"/> </Profile>
        <Profile name="wtBtnHit"  extends="emptyPanel"       with="anchorTopCenter"> <size value="44px 16px"/> <isFocusable value="true"/> </Profile>

        <!-- Delete button (red) — verbatim CTC mgDelBg/Text/Hit -->
        <Profile name="wtDelBg"   extends="baseReference"   with="anchorTopCenter"> <size value="44px 16px"/> <imageColor value="0.28 0.08 0.08 0.95"/> </Profile>
        <Profile name="wtDelText" extends="fs25_textDefault" with="anchorTopCenter"> <size value="44px 14px"/> <textSize value="10px"/> <textBold value="true"/> <textColor value="1 0.6 0.6 1"/> <textAlignment value="center"/> </Profile>
        <Profile name="wtDelHit"  extends="emptyPanel"       with="anchorTopCenter"> <size value="44px 16px"/> <isFocusable value="true"/> </Profile>

        <!-- New Trigger button (green) — verbatim CTC mgCreateBg/Text/Hit -->
        <Profile name="wtNewBg"   extends="baseReference"   with="anchorTopCenter"> <size value="130px 20px"/> <imageColor value="0.12 0.28 0.15 0.95"/> </Profile>
        <Profile name="wtNewText" extends="fs25_textDefault" with="anchorTopCenter"> <size value="130px 16px"/> <textSize value="11px"/> <textBold value="true"/> <textColor value="0.7 1 0.7 1"/> <textAlignment value="center"/> </Profile>
        <Profile name="wtNewHit"  extends="emptyPanel"       with="anchorTopCenter"> <size value="130px 20px"/> <isFocusable value="true"/> </Profile>

        <!-- Footer -->
        <Profile name="wtFooter" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="400px 16px"/>
            <textSize value="11px"/>
            <textColor value="0.45 0.5 0.6 1"/>
            <textAlignment value="left"/>
        </Profile>

        <!-- Pagination — verbatim CTC -->
        <Profile name="wtPageBg"   extends="baseReference"   with="anchorTopCenter"> <size value="60px 16px"/> <imageColor value="0.10 0.12 0.20 0.90"/> </Profile>
        <Profile name="wtPageText" extends="fs25_textDefault" with="anchorTopCenter"> <size value="60px 14px"/> <textSize value="10px"/> <textBold value="true"/> <textColor value="0.6 0.7 0.9 1"/> <textAlignment value="center"/> </Profile>
        <Profile name="wtPageHit"  extends="emptyPanel"       with="anchorTopCenter"> <size value="60px 16px"/> <isFocusable value="true"/> </Profile>
        <Profile name="wtPageInfo" extends="fs25_textDefault" with="anchorTopCenter"> <size value="80px 14px"/> <textSize value="10px"/> <textColor value="0.5 0.55 0.65 1"/> <textAlignment value="center"/> </Profile>

    </GUIProfiles>
</GUI>
