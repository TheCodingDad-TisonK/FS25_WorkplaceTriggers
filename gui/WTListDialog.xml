<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    FS25_WorkplaceTriggers - Workplace Manager (List View)
    3-layer button pattern: Bitmap bg + Text label + invisible Button hit area.
    Rows: up to 8 triggers shown with Edit and Delete per row.
    anchorTopCenter: X=0 is center, negative=left, positive=right.
    Element CENTER (not left edge) is placed at the X position.

    Column layout (centers, 750px dialog, content range approx +-345px):
      Name (200px wide):  center=-235px  left=-335  right=-135
      Wage (90px wide):   center=-82px   left=-127  right=-37
      Sched (110px wide): center=26px    left=-29   right=81
      Edit (48px wide):   center=242px   left=218   right=266
      Del  (48px wide):   center=298px   left=274   right=322

    Layout (Y from top, increases downward):
      -12    Title
      -34    Subtitle
      -50    Divider
      -54    Column headers: Name | Wage | Sched/Radius
      -70    Header underline
      -74    Row 1  (24px tall; step = 26px between rows)
      -100   Row 2
      -126   Row 3
      -152   Row 4
      -178   Row 5
      -204   Row 6
      -230   Row 7
      -256   Row 8
      -282   Bottom divider
      -288   Status / count text
      -310   Pagination: Prev | page info | Next
-->
<GUI onOpen="onOpen" onClose="wtOnClose" onCreate="onCreate">
    <GuiElement profile="newLayer" />
    <Bitmap profile="dialogFullscreenBg" id="dialogBg" />

    <GuiElement profile="dialogBg" id="dialogElement" size="750px 520px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle" />
        <ThreePartBitmap profile="fs25_dialogBgTop" />
        <ThreePartBitmap profile="fs25_dialogBgBottom" />

        <GuiElement profile="fs25_dialogContentContainer">

            <!-- Title -->
            <Text profile="wtTitle"    id="titleText"    position="0px -12px" text="Workplace Triggers"/>
            <Text profile="wtSubtitle" id="subtitleText" position="0px -34px" text="Manage your workplace trigger zones"/>

            <!-- Header divider -->
            <Bitmap profile="wtDivider" position="0px -50px"/>

            <!-- Column headers -->
            <Text profile="wtHdrName"  position="-235px -54px" text="Workplace Name"/>
            <Text profile="wtHdrWage"  position="-82px  -54px" text="Wage"/>
            <Text profile="wtHdrPos"   position="26px   -54px" text="Sched / Radius"/>

            <!-- Header underline -->
            <Bitmap profile="wtDivider" position="0px -70px"/>

            <!-- ROW 1 -->
            <Bitmap profile="wtRowOdd"  id="r1bg"      position="0px    -74px"/>
            <Text profile="wtCellName"  id="r1name"    position="-235px -75px" text=""/>
            <Text profile="wtCellWage"  id="r1wage"    position="-82px  -75px" text=""/>
            <Text profile="wtCellPos"   id="r1pos"     position="26px   -75px" text=""/>
            <Bitmap profile="wtBtnBg"      id="r1editbg"  position="242px -75px"/>
            <Text   profile="wtBtnText"    id="r1edittxt" position="242px -76px" text="Edit"/>
            <Button profile="wtBtnHit"     id="r1edit"    position="242px -75px" onClick="onClickEdit1" toolTip="Edit trigger"/>
            <Bitmap profile="wtBtnDelBg"   id="r1delbg"   position="298px -75px"/>
            <Text   profile="wtBtnText"    id="r1deltxt"  position="298px -76px" text="Del"/>
            <Button profile="wtBtnHit"     id="r1del"     position="298px -75px" onClick="onClickDel1" toolTip="Delete trigger"/>

            <!-- ROW 2 -->
            <Bitmap profile="wtRowEven" id="r2bg"      position="0px    -100px"/>
            <Text profile="wtCellName"  id="r2name"    position="-235px -101px" text=""/>
            <Text profile="wtCellWage"  id="r2wage"    position="-82px  -101px" text=""/>
            <Text profile="wtCellPos"   id="r2pos"     position="26px   -101px" text=""/>
            <Bitmap profile="wtBtnBg"      id="r2editbg"  position="242px -101px"/>
            <Text   profile="wtBtnText"    id="r2edittxt" position="242px -102px" text="Edit"/>
            <Button profile="wtBtnHit"     id="r2edit"    position="242px -101px" onClick="onClickEdit2" toolTip="Edit trigger"/>
            <Bitmap profile="wtBtnDelBg"   id="r2delbg"   position="298px -101px"/>
            <Text   profile="wtBtnText"    id="r2deltxt"  position="298px -102px" text="Del"/>
            <Button profile="wtBtnHit"     id="r2del"     position="298px -101px" onClick="onClickDel2" toolTip="Delete trigger"/>

            <!-- ROW 3 -->
            <Bitmap profile="wtRowOdd"  id="r3bg"      position="0px    -126px"/>
            <Text profile="wtCellName"  id="r3name"    position="-235px -127px" text=""/>
            <Text profile="wtCellWage"  id="r3wage"    position="-82px  -127px" text=""/>
            <Text profile="wtCellPos"   id="r3pos"     position="26px   -127px" text=""/>
            <Bitmap profile="wtBtnBg"      id="r3editbg"  position="242px -127px"/>
            <Text   profile="wtBtnText"    id="r3edittxt" position="242px -128px" text="Edit"/>
            <Button profile="wtBtnHit"     id="r3edit"    position="242px -127px" onClick="onClickEdit3" toolTip="Edit trigger"/>
            <Bitmap profile="wtBtnDelBg"   id="r3delbg"   position="298px -127px"/>
            <Text   profile="wtBtnText"    id="r3deltxt"  position="298px -128px" text="Del"/>
            <Button profile="wtBtnHit"     id="r3del"     position="298px -127px" onClick="onClickDel3" toolTip="Delete trigger"/>

            <!-- ROW 4 -->
            <Bitmap profile="wtRowEven" id="r4bg"      position="0px    -152px"/>
            <Text profile="wtCellName"  id="r4name"    position="-235px -153px" text=""/>
            <Text profile="wtCellWage"  id="r4wage"    position="-82px  -153px" text=""/>
            <Text profile="wtCellPos"   id="r4pos"     position="26px   -153px" text=""/>
            <Bitmap profile="wtBtnBg"      id="r4editbg"  position="242px -153px"/>
            <Text   profile="wtBtnText"    id="r4edittxt" position="242px -154px" text="Edit"/>
            <Button profile="wtBtnHit"     id="r4edit"    position="242px -153px" onClick="onClickEdit4" toolTip="Edit trigger"/>
            <Bitmap profile="wtBtnDelBg"   id="r4delbg"   position="298px -153px"/>
            <Text   profile="wtBtnText"    id="r4deltxt"  position="298px -154px" text="Del"/>
            <Button profile="wtBtnHit"     id="r4del"     position="298px -153px" onClick="onClickDel4" toolTip="Delete trigger"/>

            <!-- ROW 5 -->
            <Bitmap profile="wtRowOdd"  id="r5bg"      position="0px    -178px"/>
            <Text profile="wtCellName"  id="r5name"    position="-235px -179px" text=""/>
            <Text profile="wtCellWage"  id="r5wage"    position="-82px  -179px" text=""/>
            <Text profile="wtCellPos"   id="r5pos"     position="26px   -179px" text=""/>
            <Bitmap profile="wtBtnBg"      id="r5editbg"  position="242px -179px"/>
            <Text   profile="wtBtnText"    id="r5edittxt" position="242px -180px" text="Edit"/>
            <Button profile="wtBtnHit"     id="r5edit"    position="242px -179px" onClick="onClickEdit5" toolTip="Edit trigger"/>
            <Bitmap profile="wtBtnDelBg"   id="r5delbg"   position="298px -179px"/>
            <Text   profile="wtBtnText"    id="r5deltxt"  position="298px -180px" text="Del"/>
            <Button profile="wtBtnHit"     id="r5del"     position="298px -179px" onClick="onClickDel5" toolTip="Delete trigger"/>

            <!-- ROW 6 -->
            <Bitmap profile="wtRowEven" id="r6bg"      position="0px    -204px"/>
            <Text profile="wtCellName"  id="r6name"    position="-235px -205px" text=""/>
            <Text profile="wtCellWage"  id="r6wage"    position="-82px  -205px" text=""/>
            <Text profile="wtCellPos"   id="r6pos"     position="26px   -205px" text=""/>
            <Bitmap profile="wtBtnBg"      id="r6editbg"  position="242px -205px"/>
            <Text   profile="wtBtnText"    id="r6edittxt" position="242px -206px" text="Edit"/>
            <Button profile="wtBtnHit"     id="r6edit"    position="242px -205px" onClick="onClickEdit6" toolTip="Edit trigger"/>
            <Bitmap profile="wtBtnDelBg"   id="r6delbg"   position="298px -205px"/>
            <Text   profile="wtBtnText"    id="r6deltxt"  position="298px -206px" text="Del"/>
            <Button profile="wtBtnHit"     id="r6del"     position="298px -205px" onClick="onClickDel6" toolTip="Delete trigger"/>

            <!-- ROW 7 -->
            <Bitmap profile="wtRowOdd"  id="r7bg"      position="0px    -230px"/>
            <Text profile="wtCellName"  id="r7name"    position="-235px -231px" text=""/>
            <Text profile="wtCellWage"  id="r7wage"    position="-82px  -231px" text=""/>
            <Text profile="wtCellPos"   id="r7pos"     position="26px   -231px" text=""/>
            <Bitmap profile="wtBtnBg"      id="r7editbg"  position="242px -231px"/>
            <Text   profile="wtBtnText"    id="r7edittxt" position="242px -232px" text="Edit"/>
            <Button profile="wtBtnHit"     id="r7edit"    position="242px -231px" onClick="onClickEdit7" toolTip="Edit trigger"/>
            <Bitmap profile="wtBtnDelBg"   id="r7delbg"   position="298px -231px"/>
            <Text   profile="wtBtnText"    id="r7deltxt"  position="298px -232px" text="Del"/>
            <Button profile="wtBtnHit"     id="r7del"     position="298px -231px" onClick="onClickDel7" toolTip="Delete trigger"/>

            <!-- ROW 8 -->
            <Bitmap profile="wtRowEven" id="r8bg"      position="0px    -256px"/>
            <Text profile="wtCellName"  id="r8name"    position="-235px -257px" text=""/>
            <Text profile="wtCellWage"  id="r8wage"    position="-82px  -257px" text=""/>
            <Text profile="wtCellPos"   id="r8pos"     position="26px   -257px" text=""/>
            <Bitmap profile="wtBtnBg"      id="r8editbg"  position="242px -257px"/>
            <Text   profile="wtBtnText"    id="r8edittxt" position="242px -258px" text="Edit"/>
            <Button profile="wtBtnHit"     id="r8edit"    position="242px -257px" onClick="onClickEdit8" toolTip="Edit trigger"/>
            <Bitmap profile="wtBtnDelBg"   id="r8delbg"   position="298px -257px"/>
            <Text   profile="wtBtnText"    id="r8deltxt"  position="298px -258px" text="Del"/>
            <Button profile="wtBtnHit"     id="r8del"     position="298px -257px" onClick="onClickDel8" toolTip="Delete trigger"/>

            <!-- Bottom divider -->
            <Bitmap profile="wtDivider" id="bottomDivider" position="0px -282px"/>

            <!-- Status / count text -->
            <Text profile="wtFooter" id="statusText" position="0px -288px" text=""/>

            <!-- Pagination: Prev | page info | Next -->
            <Bitmap profile="wtPageBg"   id="prevBg"   position="-120px -310px"/>
            <Text   profile="wtPageText" id="prevText" position="-120px -311px" text="&lt; Prev"/>
            <Button profile="wtPageHit"  id="prevBtn"  position="-120px -310px" onClick="onClickPrev"/>

            <Text   profile="wtPageInfo" id="pageInfo" position="-35px -312px"  text="1 / 1"/>

            <Bitmap profile="wtPageBg"   id="nextBg"   position="50px  -310px"/>
            <Text   profile="wtPageText" id="nextText" position="50px  -311px"  text="Next &gt;"/>
            <Button profile="wtPageHit"  id="nextBtn"  position="50px  -310px"  onClick="onClickNext"/>

        </GuiElement>

        <!-- Bottom button bar: New Trigger | Close -->
        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonOK"   id="btnNew"   text="+ New Trigger" onClick="onClickNew"/>
            <Button profile="buttonBack" id="btnClose" text="Close"         onClick="onClickClose"/>
        </BoxLayout>

    </GuiElement>

    <GUIProfiles>
        <Profile name="fs25_guiElement" extends="baseReference"/>

        <Profile name="wtTitle" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="700px 22px"/>
            <textSize value="20px"/>
            <textBold value="true"/>
            <textColor value="1 1 1 1"/>
            <textAlignment value="center"/>
        </Profile>

        <Profile name="wtSubtitle" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="700px 16px"/>
            <textSize value="12px"/>
            <textColor value="0.55 0.75 0.9 1"/>
            <textAlignment value="center"/>
        </Profile>

        <Profile name="wtDivider" extends="baseReference" with="anchorTopCenter">
            <size value="690px 1px"/>
            <imageColor value="0.28 0.38 0.55 0.8"/>
        </Profile>

        <!-- Column headers -->
        <Profile name="wtHdrBase" extends="fs25_textDefault" with="anchorTopCenter">
            <textSize value="11px"/>
            <textBold value="true"/>
            <textColor value="0.55 0.7 0.9 1"/>
        </Profile>
        <Profile name="wtHdrName" extends="wtHdrBase" with="anchorTopCenter"> <size value="200px 14px"/> <textAlignment value="left"/> </Profile>
        <Profile name="wtHdrWage" extends="wtHdrBase" with="anchorTopCenter"> <size value="90px  14px"/> <textAlignment value="left"/> </Profile>
        <Profile name="wtHdrPos"  extends="wtHdrBase" with="anchorTopCenter"> <size value="110px 14px"/> <textAlignment value="left"/> </Profile>

        <!-- Row backgrounds — 24px tall -->
        <Profile name="wtRowOdd" extends="baseReference" with="anchorTopCenter">
            <size value="690px 24px"/>
            <imageColor value="0.08 0.09 0.13 0.6"/>
        </Profile>
        <Profile name="wtRowEven" extends="baseReference" with="anchorTopCenter">
            <size value="690px 24px"/>
            <imageColor value="0.06 0.06 0.10 0.4"/>
        </Profile>

        <!-- Table cells -->
        <Profile name="wtCellName" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="200px 22px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textColor value="1 1 1 1"/>
            <textAlignment value="left"/>
        </Profile>
        <Profile name="wtCellWage" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="90px 22px"/>
            <textSize value="12px"/>
            <textColor value="0.35 0.88 0.42 1"/>
            <textAlignment value="left"/>
        </Profile>
        <Profile name="wtCellPos" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="110px 22px"/>
            <textSize value="11px"/>
            <textColor value="0.62 0.72 0.85 1"/>
            <textAlignment value="left"/>
        </Profile>

        <!-- Edit button (blue) -->
        <Profile name="wtBtnBg" extends="baseReference" with="anchorTopCenter">
            <size value="48px 22px"/>
            <imageColor value="0.14 0.30 0.62 1"/>
        </Profile>
        <Profile name="wtBtnText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="48px 20px"/>
            <textSize value="10px"/>
            <textBold value="true"/>
            <textColor value="1 1 1 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="wtBtnHit" extends="emptyPanel" with="anchorTopCenter">
            <size value="48px 22px"/>
            <isFocusable value="true"/>
        </Profile>

        <!-- Delete button (red) -->
        <Profile name="wtBtnDelBg" extends="baseReference" with="anchorTopCenter">
            <size value="48px 22px"/>
            <imageColor value="0.52 0.08 0.08 1"/>
        </Profile>

        <!-- Pagination buttons -->
        <Profile name="wtPageBg" extends="baseReference" with="anchorTopCenter">
            <size value="70px 20px"/>
            <imageColor value="0.10 0.12 0.20 0.90"/>
        </Profile>
        <Profile name="wtPageText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="70px 18px"/>
            <textSize value="10px"/>
            <textBold value="true"/>
            <textColor value="0.6 0.7 0.9 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="wtPageHit" extends="emptyPanel" with="anchorTopCenter">
            <size value="70px 20px"/>
            <isFocusable value="true"/>
        </Profile>
        <Profile name="wtPageInfo" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="80px 18px"/>
            <textSize value="11px"/>
            <textColor value="0.5 0.55 0.65 1"/>
            <textAlignment value="center"/>
        </Profile>

        <Profile name="wtFooter" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="700px 16px"/>
            <textSize value="11px"/>
            <textColor value="0.45 0.55 0.65 1"/>
            <textAlignment value="center"/>
        </Profile>

    </GUIProfiles>
</GUI>
